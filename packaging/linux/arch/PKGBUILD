# Maintainer: ProgSphinx <progsphp@gmail.com>
pkgname=sage
pkgver=0.1.0
pkgrel=4
pkgdesc="Personal knowledge widget - memorize and query notes via AI"
arch=('x86_64')
url="https://progsphinx.gumroad.com/l/bwobty"
license=('MIT')
depends=()
optdepends=('desktop-file-utils: update desktop database'
            'gtk-update-icon-cache: update icon cache')
options=('!strip')
install=sage.install
source=("sage"
        "sage.png"
        "sage.desktop")
sha256sums=('SKIP' 'SKIP' 'SKIP')
noextract=('sage')

package() {
    install -Dm755 "$srcdir/sage" "$pkgdir/usr/bin/sage"
    install -Dm644 "$srcdir/sage.png" "$pkgdir/usr/share/icons/hicolor/512x512/apps/sage.png"
    install -Dm644 "$srcdir/sage.desktop" "$pkgdir/usr/share/applications/sage.desktop"
}
