<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package Name="Sage"
           Version="$(var.Version)"
           Manufacturer="Sage"
           UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
           Language="1033"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perUser">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Sage is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Install directory -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="Sage">

        <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
          <File Id="SageExe" Source="$(var.ExePath)" KeyPath="yes" />
        </Component>

      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <Shortcut Id="SageStartMenu"
                  Name="Sage"
                  Target="[INSTALLFOLDER]sage.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="SageIcon" />
        <RemoveFolder Id="RemoveStartMenu" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Sage" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="D4E5F6A7-B8C9-0123-DEFA-234567890123">
        <Shortcut Id="SageDesktop"
                  Name="Sage"
                  Target="[INSTALLFOLDER]sage.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="SageIcon" />
        <RemoveFolder Id="RemoveDesktop" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Sage" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Complete" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>

    <Icon Id="SageIcon" SourceFile="$(var.ExePath)" />

  </Package>
</Wix>
